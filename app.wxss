/* app.wxss - 全局样式 */

/* 颜色变量 */
page {
  --primary-color: #07C160;
  --warning-color: #FA9E2C;
  --bg-color: #F5F5F5;
  --card-bg: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #999999;
  --border-color: #E5E5E5;

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 通用类 */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
}

.card {
  background-color: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background-color: var(--primary-color);
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background-color: #cccccc;
  color: #ffffff;
}

.btn-warning {
  background-color: var(--warning-color);
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-warning::after {
  border: none;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-pending {
  background-color: #FEF0E6;
  color: #E65400;
}

.status-processing {
  background-color: #FFF3E6;
  color: #FA9E2C;
}

.status-resolved {
  background-color: #E8F8EE;
  color: #07C160;
}

/* 间距 */
.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

/* 文字 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-primary-color {
  color: var(--primary-color);
}

.text-warning-color {
  color: var(--warning-color);
}

.text-bold {
  font-weight: 600;
}

.text-center {
  text-align: center;
}

/* 图片 */
 image {
  max-width: 100%;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}
