/* pages/publish/publish.wxss */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 24rpx;
}

.form-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.required {
  color: #E65400;
  margin-right: 8rpx;
}

.optional {
  font-size: 22rpx;
  color: #999999;
  background-color: #F5F5F5;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.label-hint {
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
  margin-left: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn image {
  width: 28rpx;
  height: 28rpx;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  border: 2rpx dashed #DDDDDD;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999999;
}

.form-action {
  margin-top: 48rpx;
  padding: 0 24rpx;
}

.btn-primary {
  background-color: #07C160;
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  width: 100%;
}

.btn-primary[disabled] {
  background-color: #cccccc;
  color: #ffffff;
}

.btn-primary::after {
  border: none;
}
