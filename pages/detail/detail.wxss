/* pages/detail/detail.wxss */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.image-swiper {
  width: 100%;
  height: 500rpx;
  background-color: #000000;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.issue-content {
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.content-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.issue-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.4;
}

.status-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.status-pending {
  background-color: #FEF0E6;
  color: #E65400;
}

.status-processing {
  background-color: #FFF3E6;
  color: #FA9E2C;
}

.status-resolved {
  background-color: #E8F8EE;
  color: #07C160;
}

.meta-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.meta-time {
  font-size: 26rpx;
  color: #999999;
  margin-right: 24rpx;
}

.meta-location {
  font-size: 26rpx;
  color: #999999;
}

.issue-desc {
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.issue-desc text {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.8;
}

/* 整改信息 */
.resolve-info {
  margin-top: 24rpx;
  padding: 20rpx;
  background-color: #F5F9F6;
  border-radius: 12rpx;
}

.resolve-header {
  margin-bottom: 12rpx;
}

.resolve-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #07C160;
}

.resolve-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.resolve-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.resolve-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

/* 互动栏 */
.interaction-bar {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.interaction-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
}

.interaction-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
}

.interaction-text {
  font-size: 28rpx;
  color: #666666;
}

.admin-btn {
  margin-left: auto;
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: #FFF3E6;
  border-radius: 24rpx;
}

.admin-btn .interaction-text {
  color: #FA9E2C;
}

/* 评论区 */
.comments-section {
  background-color: #ffffff;
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.comment-count {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #999999;
  font-weight: normal;
}

.comment-list {
  padding-bottom: 20rpx;
}

.no-comments {
  text-align: center;
  padding: 48rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 底部评论输入 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background-color: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #07C160;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.submit-btn::after {
  border: none;
}

/* 管理员面板 */
.admin-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.admin-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  max-height: 70vh;
  overflow-y: auto;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.panel-header text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.close-btn {
  width: 44rpx;
  height: 44rpx;
}

.panel-content {
  padding: 24rpx;
}

.status-options {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.status-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.status-option.active {
  background-color: #E8F8EE;
  border-color: #07C160;
}

.status-option text {
  font-size: 28rpx;
  color: #666666;
}

.status-option.active text {
  color: #07C160;
}

.status-desc-input {
  width: 100%;
  height: 160rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.status-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.status-image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.status-image-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.status-image-item .delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-image-item .delete-btn image {
  width: 24rpx;
  height: 24rpx;
}

.add-status-image {
  width: 160rpx;
  height: 160rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  border: 2rpx dashed #DDDDDD;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-status-image image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.add-status-image text {
  font-size: 22rpx;
  color: #999999;
}

.update-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07C160;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
}

.update-btn::after {
  border: none;
}
